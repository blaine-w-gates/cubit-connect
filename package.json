    "next": "16.2.4",
    "next-themes": "0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "10.1.0",
    "react-to-print": "3.2.0",
    "react-virtuoso": "4.18.1",
    "rehype-sanitize": "6.0.0",
    "remark-breaks": "4.0.0",
    "sonner": "2.0.7",
    "tailwind-merge": "3.4.0",
    "tailwindcss-animate": "1.0.7",
    "yjs": "^13.6.29",
    "zod": "4.3.6",
